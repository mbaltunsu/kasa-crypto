# ─────────────────────────────── Database ───────────────────────────────
DATABASE_URL=postgresql+psycopg://kasa:kasa@localhost:5433/kasa
POSTGRES_USER=kasa
POSTGRES_PASSWORD=kasa
POSTGRES_DB=kasa

# ─────────────────────────────── Auth ───────────────────────────────
JWT_SECRET=change-me-dev-only
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# ───────────── Custodial wallet — DEV ONLY (prod uses KMS/HSM, never an env mnemonic) ─────────────
# Default is the well-known Hardhat test mnemonic — NEVER use with real funds.
MASTER_MNEMONIC="test test test test test test test test test test test junk"
FAUCET_PRIVATE_KEY=

# ───────────── Contracts: deploy + verify (testnets only) ─────────────
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
SNOWTRACE_API_KEY=

# ───────────── RPC — env-driven, comma-separated fallback lists (names match registry rpcEnv) ─────────────
RPC_ETHEREUM_SEPOLIA=https://ethereum-sepolia.publicnode.com,https://rpc.sepolia.org
RPC_AVALANCHE_FUJI=https://api.avax-test.network/ext/bc/C/rpc

# Confirmations before a deposit is credited (per chain default)
DEPOSIT_CONFIRMATIONS=5

# ───────────── Chain workers (watcher + withdrawal processor) — all optional, sane defaults ─────────────
REORG_DEPTH=5                 # extra reorg-detection margin beyond the confirmation depth
BLOCK_CHUNK_SIZE=2000         # max blocks per get_logs request
WATCHER_POLL_SECONDS=10
WITHDRAWER_POLL_SECONDS=10
RPC_MAX_RETRIES=3
RPC_REQUEST_TIMEOUT=20
# Set to 1 to make /admin/reserves read live on-chain balances (needs reachable RPC); else ledger-only.
RESERVES_ONCHAIN=0

# ───────────── Demo convenience ─────────────
# Seed a known login at API startup so the prefilled login form works with one click (demo only).
SEED_DEMO_USER=1
DEMO_EMAIL=demo@kasa.app
DEMO_PASSWORD=kasademo123

# ─────────────────────────────── Frontend ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
