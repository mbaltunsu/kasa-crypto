{
  "$ref": "#/definitions/Chain",
  "definitions": {
    "Chain": {
      "type": "object",
      "properties": {
        "chainId": {
          "type": "integer",
          "exclusiveMinimum": true,
          "minimum": 0
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "nativeSymbol": {
          "type": "string",
          "minLength": 1
        },
        "coinType": {
          "type": "integer",
          "minimum": 0
        },
        "rpcEnv": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "explorerTxUrl": {
          "type": "string",
          "pattern": "\\{hash\\}"
        },
        "explorerAddressUrl": {
          "type": "string",
          "pattern": "\\{address\\}"
        },
        "assets": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "native"
                  },
                  "symbol": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "decimals": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "type",
                  "symbol",
                  "name",
                  "decimals"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "erc20"
                  },
                  "symbol": {
                    "$ref": "#/definitions/Chain/properties/assets/items/anyOf/0/properties/symbol"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "decimals": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "address": {
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{40}$"
                  },
                  "deploymentBlock": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "required": [
                  "type",
                  "symbol",
                  "name",
                  "decimals",
                  "address"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "erc721"
                  },
                  "symbol": {
                    "$ref": "#/definitions/Chain/properties/assets/items/anyOf/0/properties/symbol"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "decimals": {
                    "type": "number",
                    "const": 0
                  },
                  "address": {
                    "$ref": "#/definitions/Chain/properties/assets/items/anyOf/1/properties/address"
                  },
                  "deploymentBlock": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "required": [
                  "type",
                  "symbol",
                  "name",
                  "decimals",
                  "address"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1
        }
      },
      "required": [
        "chainId",
        "name",
        "displayName",
        "nativeSymbol",
        "coinType",
        "rpcEnv",
        "explorerTxUrl",
        "explorerAddressUrl",
        "assets"
      ],
      "additionalProperties": false
    }
  }
}
